{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Agenda",
  "version": "0.1.1",
  "identifier": "com.calendario.widget",
  "build": {
    "beforeDevCommand": "npm run build:frontend",
    "beforeBuildCommand": "npm run build:frontend",
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Agenda",
        "width": 380,
        "height": 520,
        "minWidth": 280,
        "minHeight": 320,
        "resizable": true,
        "maximizable": true,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "focus": true,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "Calendário widget e app para Windows",
    "longDescription": "Calendário leve com modo widget e integração Google Calendar (em desenvolvimento)."
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["agenda"]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVBNEFFQ0MwRjU5M0QwNkYKUldSdjBKUDF3T3hLNmtoMWJDdTM4OXVRYWVWZCszUUFEd3FRL2JWTG1zYi9TU0t2Vkxmd3N3M1UK",
      "endpoints": [
        "https://github.com/LisboaAnt/schedule-desktop/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
