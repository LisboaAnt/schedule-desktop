{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Agenda",
  "version": "0.1.0-beta.1",
  "identifier": "com.calendario.widget",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Agenda",
        "width": 380,
        "height": 520,
        "minWidth": 280,
        "minHeight": 320,
        "resizable": true,
        "maximizable": true,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "focus": true,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "Calendário widget e app para Windows",
    "longDescription": "Calendário leve com modo widget e integração Google Calendar (em desenvolvimento)."
  }
}
